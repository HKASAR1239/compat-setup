+class JSONEncoder(json.JSONEncoder):
+    def default(self, o):
+        if dataclasses.is_dataclass(o):
+            return dataclasses.asdict(o)
+
+        if hasattr(o, "to_json"):
+            return o.to_json()
+
+        if hasattr(o, "json"):
+            return o.json()
+
+        if hasattr(o, "__class__"):
+            return o.__class__.__name__
+
+        return super().default(o)
